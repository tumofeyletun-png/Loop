		for(j = 0; j < n; j++){
			printf("%d.%d. = ", i, j);
			scanf("%lf", & matrix2[i][j]);
		}
	}
	
    printf("Input '+', '-','*': ");
    scanf(" %c", &oper);
    
    double **matrix = matr(matrix1, matrix2, n , oper);
	for(i1 = 0; i1 < n; i1++){
		for(j1 = 0; j1 < n; j1++){
			printf("%lf", matrix[i1][j1]);
		}
		printf("\n");
