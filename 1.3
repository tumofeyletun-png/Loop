int matr_min(double mar1[2][2], double mar2[2][2], double mar3[2][2]){
	int i,j;
	int n = 3;
	
	for(i = 0; i < n; i++){
		for(j = 0; j < n; j++){
			mar3[i][j] = mar1[i][j] - mar2[i][j]; 
		}
	}
	return 0;
}

int matr_mnoh(double mar1[2][2], double mar2[2][2], double mar3[2][2]){
	int i,j,k;
	int n = 3;
	
	for(i = 0; i < n; i++){
		for(j = 0; j < n; j++){
			for(k = 0; k < n; k++){
				mar3[i][j] += mar1[i][k] * mar2[k][j];
			}
		}
	}
	return 0;
}


   
