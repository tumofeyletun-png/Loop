#include <stdio.h>
#include <stdlib.h>

double **matr(double **m1, double **m2, int n, char oper){
	int i = 0, j = 0, k = 0;
	
	double **matrix = (double**)malloc(n * sizeof(double*));

	for (i = 0; i < n; i++){
		matrix[i] = (double*)malloc(n * sizeof(double));
	}
	if(oper == '+'){
		for(i = 0; i < n; i++){
			for(j =0; j < n; j++){
				matrix[i][j] = m1[i][j] + m2[i][j];
			}
		}
	}
	else if(oper == '-'){
		for(i = 0; i < n; i++){
			for(j =0; j < n; j++){
				matrix[i][j] = m1[i][j] - m2[i][j];
			}
		}
	}
	else if(oper == '*'){
		for(i = 0; i < n; i++){
			for(j =0; j < n; j++){
				matrix[i][j] = 0;
				for(k = 0; k < n; k++){
					matrix[i][j] += m1[i][k] * m2[k][j];
				}
			}
		}
	}
	return matrix;
}
