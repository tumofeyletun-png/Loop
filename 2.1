#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <stdbool.h>

double per(double a, double b, double c){
	return a + b + c;
}

double plos(double a, double b, double c){
	double p;
	double sum;
	
	p = (a + b + c) / 2.0;
	
	sum = (sqrt(p*(p-a)*(p-b)*(p-c)));
	
	return sum; 
}
bool prov(double a, double b, double c){
	return (a + b > c) && (a + c > b) && (c + b > a);
}
